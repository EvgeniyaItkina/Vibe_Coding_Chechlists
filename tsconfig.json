{
    "compilerOptions": {
        "target": "ES2020",
        "module": "NodeNext",
        "lib": [
            "ES2020",
            "DOM"
        ],
         "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "moduleResolution": "nodenext"
    },
    "include": [
        "backend/**/*",
        "frontend/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}