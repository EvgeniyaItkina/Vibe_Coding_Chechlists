{
  "name": "todo-checklist-app",
  "version": "1.0.0",
  "description": "Simple to-do checklist application with HTML/CSS/TypeScript frontend and Node.js backend",
  "type": "module",
  "main": "dist/backend/server.js",
  "scripts": {
    "build": "tsc && npm run copy",
    "copy": "copyfiles -u 1 frontend/index.html frontend/styles.css dist/frontend",
    "start": "node dist/backend/server.js",
    "dev": "ts-node backend/server.ts"
  },
  "keywords": [
    "todo",
    "checklist"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "copyfiles": "^2.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.3"
  }
}
